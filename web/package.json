{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,firebase -c blue,yellow npm:dev:vite npm:dev:emulators",
    "dev:vite": "vite",
    "dev:emulators": "npm run --silent ensure-java && npm run --silent kill-stale-emulators && firebase emulators:start --only auth,database --project demo-digitalicebreakers",
    "dev:emulators:e2e": "npm run --silent ensure-java && npm run --silent kill-stale-emulators:e2e && firebase emulators:start --only auth,database --project demo-digitalicebreakers --config firebase.e2e.json",
    "kill-stale-emulators": "lsof -ti :9000 -ti :9099 | xargs kill 2>/dev/null || true",
    "kill-stale-emulators:e2e": "lsof -ti :9200 -ti :9299 | xargs kill 2>/dev/null || true",
    "ensure-java": "command -v java >/dev/null 2>&1 || { echo 'Java is required by the Firebase emulator. Install it with: brew install openjdk && sudo ln -sfn /opt/homebrew/opt/openjdk/libexec/openjdk.jdk /Library/Java/JavaVirtualMachines/openjdk.jdk'; exit 1; }",
    "test:rules": "npm run --silent ensure-java && firebase emulators:exec --only database --project demo-rules --config firebase.rules-test.json \"vitest run --config vitest.rules.config.ts\"",
    "check-types": "tsc -b --noEmit",
    "check-types:e2e": "tsc --project tsconfig.e2e.json --noEmit",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:e2e": "eslint e2e/**/*.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:install": "npx playwright install --with-deps chromium",
    "e2e": "npx playwright test",
    "e2e:headed": "HEADED=true npx playwright test --headed"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/roboto": "^5.2.5",
    "@mui/icons-material": "^7.0.2",
    "@mui/material": "^7.0.2",
    "@mui/styles": "^6.4.11",
    "classnames": "^2.5.1",
    "color": "^5.0.0",
    "file-saver": "^2.0.5",
    "firebase": "^12.14.0",
    "gsap": "^3.12.7",
    "history": "^5.3.0",
    "jotai": "^2.12.5",
    "luxon": "^3.6.1",
    "perfect-scrollbar": "^1.5.6",
    "pixi.js": "^4.8.3",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.5.1",
    "recharts": "^2.15.3",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.53.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.1",
    "@types/pixi.js": "^4.8.3",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^3.2.4",
    "concurrently": "^10.0.3",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "firebase-tools": "^15.19.1",
    "globals": "^16.0.0",
    "happy-dom": "^18.0.1",
    "jsdom": "^26.1.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.3.1",
    "vitest": "^3.2.4"
  }
}
